{% block content %}
    <div {{ attributes.defaults({ class: 'ux-search-hits' }) }}>
        {% if results.hits|length > 0 %}
            <div class="row g-2">
                {% for hit in results.hits %}
                    {% set postcard = hit.data %}
                    <div class="col-6 col-md-4">
                        <div class="card h-100 border-0 shadow-sm">
                            {% if postcard.thumbnailUrl %}
                                <img src="{{ postcard.thumbnailUrl }}" class="card-img-top" alt="{{ postcard.title }}" loading="lazy" style="height: 120px; object-fit: contain; background: #f8f9fa;">
                            {% endif %}
                            <div class="card-body p-2">
                                <h3 class="h6 card-title mb-1 text-truncate">{{ postcard.aiTitle ?: postcard.title }}</h3>
                                {% if postcard.aiCity or postcard.aiState or postcard.aiCountry %}
                                    <div class="small text-muted mb-1">
                                        {% if postcard.aiCity %}{{ postcard.aiCity }}, {% endif %}{% if postcard.aiState %}{{ postcard.aiState }}, {% endif %}{{ postcard.aiCountry }}
                                    </div>
                                {% endif %}
                                <p class="small mb-1 text-truncate" style="max-height: 2.8em;">{{ postcard.aiDescription ?: postcard.description ?: 'No description yet.' }}</p>
                                {% if postcard.keywords|default([])|length > 0 %}
                                    <div class="d-flex flex-wrap gap-1">
                                        {% for keyword in postcard.keywords|slice(0, 6) %}
                                            {% set conf = keyword.confidence ?? 0 %}
                                            {% set confPct = (conf * 100)|round %}
                                            {% set color = confPct >= 80 ? 'success' : (confPct >= 50 ? 'warning' : 'secondary') %}
                                            {% set fs = confPct >= 80 ? '1em' : (confPct >= 50 ? '0.9em' : '0.8em') %}
                                            <span class="badge text-bg-{{ color }}" style="font-size: {{ fs }}" title="Confidence: {{ confPct }}%{% if keyword.basis %}; Basis: {{ keyword.basis }}{% endif %}">{{ keyword.value }}</span>
                                        {% endfor %}
                                    </div>
                                {% elseif postcard.aiKeywords|default([])|length > 0 %}
                                    <div class="d-flex flex-wrap gap-1">
                                        {% for keyword in postcard.aiKeywords|default([])|slice(0, 6) %}
                                            <span class="badge text-bg-light">{{ keyword }}</span>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                <div class="mt-2">
                                    <a class="btn btn-sm btn-outline-primary py-0 px-1" href="{{ path('app_postcard_show', {id: postcard.id}) }}">Open</a>
                                    {% if postcard.rawData.citation_url %}
                                        <a href="{{ postcard.rawData.citation_url }}" target="_blank" class="btn btn-sm btn-outline-secondary py-0 px-1">Original</a>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="alert alert-light border">No postcards found.</div>
        {% endif %}
    </div>
{% endblock %}
